---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% for page in site.pages %}
  {% unless page.url contains "sitemap" or page.url contains "404" %}
  <url>
    <loc>{{ site.url }}{{ page.url | remove: "index.html" | uri_escape }}</loc>
    {% if page.last_modified_at %}
    <lastmod>{{ page.last_modified_at | date: "%Y-%m-%d" }}</lastmod>
    {% endif %}
    <changefreq>weekly</changefreq>
    <priority>{% if page.url == "/" %}1.0{% elsif page.url contains "/product/" %}0.8{% else %}0.6{% endif %}</priority>
  </url>
  {% endunless %}
  {% endfor %}
</urlset>
